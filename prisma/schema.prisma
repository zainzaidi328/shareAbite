// ShareBite database schema.
// Dev default is SQLite so the app runs with zero external services.
// To deploy on PostgreSQL (Railway/Supabase): change provider to "postgresql",
// set DATABASE_URL, and run `prisma db push`. The schema is intentionally
// portable (string-based enums, no db-specific types).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role: DONOR | RECIPIENT | NGO | ADMIN
// (string instead of enum so SQLite and Postgres both work)
model User {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String
  passwordHash  String
  role          String   @default("RECIPIENT")
  address       String
  city          String
  latitude      Float
  longitude     Float
  avatarUrl     String?
  bio           String?
  foodPrefs     String? // comma-separated: Vegetarian,Halal,...
  emailVerified Boolean  @default(false)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  donations        FoodDonation[]
  requests         DonationRequest[]
  sentMessages     Message[]         @relation("SentMessages")
  notifications    Notification[]
  reviewsGiven     Review[]          @relation("ReviewsGiven")
  reviewsReceived  Review[]          @relation("ReviewsReceived")
  favoritesAsUser  Favorite[]        @relation("FavoriteOwner")
  favoritesAsDonor Favorite[]        @relation("FavoriteDonor")
  ngoProfile       NgoProfile?
  tokens           AuthToken[]
  conversationsA   Conversation[]    @relation("ConvA")
  conversationsB   Conversation[]    @relation("ConvB")
}

model NgoProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  organizationName String
  registrationNo   String
  description      String?
  approved         Boolean  @default(false)
  volunteers       Int      @default(0)
  createdAt        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Status: ACTIVE | RESERVED | COMPLETED | EXPIRED | REMOVED
model FoodDonation {
  id           String    @id @default(cuid())
  donorId      String
  title        String
  description  String
  category     String // Vegetarian | Vegan | Halal | Bakery | Dairy | CookedMeal | Fruit | Vegetables | Beverages | Dessert | Other
  quantity     Int
  servingSize  String
  cookedAt     DateTime?
  expiresAt    DateTime
  pickupStart  DateTime
  pickupEnd    DateTime
  address      String
  city         String
  latitude     Float
  longitude    Float
  imageUrl     String?
  instructions String?
  status       String    @default("ACTIVE")
  isVegetarian Boolean   @default(false)
  isHalal      Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  donor    User              @relation(fields: [donorId], references: [id], onDelete: Cascade)
  requests DonationRequest[]
  reviews  Review[]

  @@index([status, expiresAt])
  @@index([donorId])
}

// Status: PENDING | ACCEPTED | REJECTED | COMPLETED | CANCELLED
model DonationRequest {
  id          String    @id @default(cuid())
  donationId  String
  requesterId String
  message     String?
  status      String    @default("PENDING")
  pickupCode  String? // 6-digit code, set on acceptance
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  donation  FoodDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  requester User         @relation(fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([donationId, requesterId])
  @@index([requesterId])
  @@index([status])
}

model Conversation {
  id        String   @id @default(cuid())
  userAId   String
  userBId   String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  userA    User      @relation("ConvA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User      @relation("ConvB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userAId, userBId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  body           String
  imageUrl       String?
  readAt         DateTime?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

// Type: REQUEST_RECEIVED | REQUEST_ACCEPTED | REQUEST_REJECTED | PICKUP_REMINDER | DONATION_COMPLETED | NGO_APPROVED | NEW_MESSAGE
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Review {
  id         String   @id @default(cuid())
  donationId String
  authorId   String
  targetId   String
  rating     Int // 1..5
  comment    String?
  createdAt  DateTime @default(now())

  donation FoodDonation @relation(fields: [donationId], references: [id], onDelete: Cascade)
  author   User         @relation("ReviewsGiven", fields: [authorId], references: [id], onDelete: Cascade)
  target   User         @relation("ReviewsReceived", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([donationId, authorId])
}

model Favorite {
  id      String @id @default(cuid())
  userId  String
  donorId String

  user  User @relation("FavoriteOwner", fields: [userId], references: [id], onDelete: Cascade)
  donor User @relation("FavoriteDonor", fields: [donorId], references: [id], onDelete: Cascade)

  @@unique([userId, donorId])
}

// Kind: EMAIL_VERIFY | PASSWORD_RESET
model AuthToken {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}
